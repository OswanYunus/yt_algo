{
  "manifest_version": 3,
  "name": "YT Fix",
  "version": "1.0",
  "description": "Keep autoplay in your lane — related content only.",
  "permissions": ["activeTab", "storage", "tabs"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YT Fix"
  }
}
